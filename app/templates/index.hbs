<section class="wc-hero">
    <svg class="wc-hero__pitch" viewBox="0 0 400 220" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
        <defs>
            <pattern id="stripes" x="0" y="0" width="40" height="220" patternUnits="userSpaceOnUse">
                <rect width="20" height="220" fill="rgba(255,255,255,0.025)"></rect>
            </pattern>
        </defs>
        <rect width="400" height="220" fill="url(#stripes)"></rect>
        <circle cx="200" cy="110" r="44" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="1.2"></circle>
        <line x1="200" y1="0" x2="200" y2="220" stroke="rgba(255,255,255,0.12)" stroke-width="1.2"></line>
        <rect x="0" y="70" width="42" height="80" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="1.2"></rect>
        <rect x="358" y="70" width="42" height="80" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="1.2"></rect>
    </svg>

    <div class="wc-hero__inner">
        <div class="wc-hero__copy">
            <p class="wc-hero__eyebrow"><span class="wc-hero__dot"></span>{{t 'home.dates'}}</p>
            <h1 class="wc-hero__title">{{t 'home.hero.titlePre'}} <em>{{t 'home.hero.titleEm'}}</em></h1>
            <p class="wc-hero__lede">{{t 'home.hero.lede'}}</p>
            <div class="wc-hero__cta">
                {{#link-to 'groups' class='wc-btn wc-btn--light'}}{{t 'home.cta.groups'}}{{/link-to}}
                {{#link-to 'schedule' class='wc-btn wc-btn--outline'}}{{t 'home.cta.schedule'}}{{/link-to}}
            </div>
        </div>

        <div class="wc-hero__trophy" aria-hidden="true">
            <svg viewBox="0 0 160 220" class="wc-trophy">
                <defs>
                    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#ffe38a"></stop>
                        <stop offset="45%" stop-color="#ffb627"></stop>
                        <stop offset="100%" stop-color="#c27800"></stop>
                    </linearGradient>
                    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
                        <stop offset="0%" stop-color="rgba(255,182,39,0.45)"></stop>
                        <stop offset="100%" stop-color="rgba(255,182,39,0)"></stop>
                    </radialGradient>
                </defs>
                <circle cx="80" cy="110" r="100" fill="url(#glow)"></circle>
                <path d="M54 36 Q80 10 106 36 L106 52 Q120 62 118 78 Q116 108 94 120 L94 146 L112 146 L112 158 L48 158 L48 146 L66 146 L66 120 Q44 108 42 78 Q40 62 54 52 Z"
                      fill="url(#gold)" stroke="#7a4a00" stroke-width="1.2"></path>
                <path d="M106 58 Q128 62 128 82 Q128 100 112 108" fill="none" stroke="#7a4a00" stroke-width="1.5"></path>
                <path d="M54 58 Q32 62 32 82 Q32 100 48 108" fill="none" stroke="#7a4a00" stroke-width="1.5"></path>
                <ellipse cx="80" cy="52" rx="22" ry="8" fill="#7a4a00" opacity="0.25"></ellipse>
                <rect x="36" y="170" width="88" height="16" rx="3" fill="url(#gold)" stroke="#7a4a00" stroke-width="1.2"></rect>
                <rect x="28" y="186" width="104" height="18" rx="3" fill="#3a1f00"></rect>
                <text x="80" y="199" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="800" fill="#ffd96a" letter-spacing="0.14em">FIFA WORLD CUP</text>
            </svg>
        </div>
    </div>

    <div class="wc-hero__footer">
        {{wc-countdown targetMs=model.kickoffMs}}
        <ul class="wc-stats">
            <li><span class="wc-stats__num">48</span><span class="wc-stats__label">{{t 'stats.teams'}}</span></li>
            <li><span class="wc-stats__num">12</span><span class="wc-stats__label">{{t 'stats.groups'}}</span></li>
            <li><span class="wc-stats__num">104</span><span class="wc-stats__label">{{t 'stats.matches'}}</span></li>
            <li><span class="wc-stats__num">16</span><span class="wc-stats__label">{{t 'stats.cities'}}</span></li>
        </ul>
    </div>
</section>

{{#if model.nextMatch}}
    <section class="wc-section">
        <div class="wc-section__head">
            <h2 class="wc-section__title">{{t 'home.next.title'}}</h2>
            {{#link-to 'schedule' class='wc-section__link'}}{{t 'home.next.all'}}{{/link-to}}
        </div>
        <article class="wc-next {{if model.nextMatch.isLive 'is-live'}}">
            {{add-to-calendar match=model.nextMatch}}
            <span class="wc-next__label">
                {{#if model.nextMatch.isLive}}
                    <span class="wc-live-badge wc-live-badge--solid"><span class="wc-live-badge__dot"></span>{{t 'live.now'}}</span>
                    <span class="wc-next__label-group">{{t 'group.prefix'}} {{model.nextMatch.group}}</span>
                {{else}}
                    <span class="wc-hero__dot"></span>{{t 'group.prefix'}} {{model.nextMatch.group}}
                {{/if}}
            </span>
            <div class="wc-next__teams">
                {{#if model.nextMatch.team1Code}}
                    {{#link-to 'team' model.nextMatch.team1Code class='wc-next__team'}}
                        {{#if model.nextMatch.team1Flag}}<img src={{model.nextMatch.team1Flag}} alt="">{{/if}}
                        <span>{{model.nextMatch.team1}}</span>
                    {{/link-to}}
                {{else}}
                    <div class="wc-next__team">
                        {{#if model.nextMatch.team1Flag}}<img src={{model.nextMatch.team1Flag}} alt="">{{/if}}
                        <span>{{model.nextMatch.team1}}</span>
                    </div>
                {{/if}}
                <div class="wc-next__vs">
                    <svg viewBox="0 0 32 32" class="wc-ball" aria-hidden="true">
                        <circle cx="16" cy="16" r="14" fill="#fff" stroke="#0a1128" stroke-width="1.5"></circle>
                        <polygon points="16,9 20.5,12 19,17 13,17 11.5,12" fill="#0a1128"></polygon>
                        <line x1="16" y1="2" x2="16" y2="9" stroke="#0a1128" stroke-width="1"></line>
                        <line x1="20.5" y1="12" x2="27" y2="10" stroke="#0a1128" stroke-width="1"></line>
                        <line x1="19" y1="17" x2="24" y2="23" stroke="#0a1128" stroke-width="1"></line>
                        <line x1="13" y1="17" x2="8" y2="23" stroke="#0a1128" stroke-width="1"></line>
                        <line x1="11.5" y1="12" x2="5" y2="10" stroke="#0a1128" stroke-width="1"></line>
                    </svg>
                </div>
                {{#if model.nextMatch.team2Code}}
                    {{#link-to 'team' model.nextMatch.team2Code class='wc-next__team'}}
                        {{#if model.nextMatch.team2Flag}}<img src={{model.nextMatch.team2Flag}} alt="">{{/if}}
                        <span>{{model.nextMatch.team2}}</span>
                    {{/link-to}}
                {{else}}
                    <div class="wc-next__team">
                        {{#if model.nextMatch.team2Flag}}<img src={{model.nextMatch.team2Flag}} alt="">{{/if}}
                        <span>{{model.nextMatch.team2}}</span>
                    </div>
                {{/if}}
            </div>
            <div class="wc-next__meta">
                <span><strong>{{weekday model.nextMatch.date}}, {{short-date model.nextMatch.date}}</strong></span>
                <span>{{format-time model.nextMatch.time}}</span>
                <span>{{model.nextMatch.venue}} &middot; {{model.nextMatch.city}}</span>
            </div>
        </article>
    </section>
{{/if}}

<section class="wc-section">
    <div class="wc-section__head">
        <h2 class="wc-section__title">{{t 'home.contenders.title'}}</h2>
    </div>
    <ol class="wc-contenders">
        {{#each model.contenders as |item index|}}
            {{#link-to 'team' item.team.fifaCode class='wc-contender'}}
                <span class="wc-contender__rank">{{inc index}}</span>
                {{#if item.team.flag}}<img class="wc-contender__flag" src={{item.team.flag}} alt="">{{/if}}
                <span class="wc-contender__name">{{item.team.name}}</span>
            {{/link-to}}
        {{/each}}
    </ol>
</section>

<section class="wc-section">
    <div class="wc-section__head">
        <h2 class="wc-section__title">{{t 'home.featured.title'}}</h2>
        {{#link-to 'schedule' class='wc-section__link'}}{{t 'home.featured.seeAll'}}{{/link-to}}
    </div>
    <div class="wc-featured">
        {{#each model.featured as |match|}}
            <article class="wc-card">
                <div class="wc-card__top">
                    <span class="wc-card__group">{{t 'group.prefix'}} {{match.group}}</span>
                    <span>{{weekday match.date}} &middot; {{short-date match.date}}</span>
                </div>
                <div class="wc-card__teams">
                    {{#if match.team1Code}}
                        {{#link-to 'team' match.team1Code class='wc-card__team'}}
                            {{#if match.team1Flag}}<img src={{match.team1Flag}} alt="">{{/if}}
                            <span>{{match.team1}}</span>
                        {{/link-to}}
                    {{else}}
                        <div class="wc-card__team">
                            {{#if match.team1Flag}}<img src={{match.team1Flag}} alt="">{{/if}}
                            <span>{{match.team1}}</span>
                        </div>
                    {{/if}}
                    <div class="wc-card__vs">VS</div>
                    {{#if match.team2Code}}
                        {{#link-to 'team' match.team2Code class='wc-card__team wc-card__team--right'}}
                            <span>{{match.team2}}</span>
                            {{#if match.team2Flag}}<img src={{match.team2Flag}} alt="">{{/if}}
                        {{/link-to}}
                    {{else}}
                        <div class="wc-card__team wc-card__team--right">
                            <span>{{match.team2}}</span>
                            {{#if match.team2Flag}}<img src={{match.team2Flag}} alt="">{{/if}}
                        </div>
                    {{/if}}
                </div>
                <div class="wc-card__foot">{{format-time match.time}} &middot; {{match.city}}</div>
            </article>
        {{/each}}
    </div>
</section>

<section class="wc-section">
    <div class="wc-section__head">
        <h2 class="wc-section__title">{{t 'home.hosts.title'}}</h2>
    </div>
    <ul class="wc-hosts-strip">
        <li>
            <img src="https://flagcdn.com/w160/ca.png" alt="Canada flag">
            <strong>{{t 'home.hosts.canada'}}</strong>
            <span>{{t 'home.hosts.canadaCities'}}</span>
        </li>
        <li>
            <img src="https://flagcdn.com/w160/mx.png" alt="Mexico flag">
            <strong>{{t 'home.hosts.mexico'}}</strong>
            <span>{{t 'home.hosts.mexicoCities'}}</span>
        </li>
        <li>
            <img src="https://flagcdn.com/w160/us.png" alt="USA flag">
            <strong>{{t 'home.hosts.usa'}}</strong>
            <span>{{t 'home.hosts.usaCities'}}</span>
        </li>
    </ul>
</section>
