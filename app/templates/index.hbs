<section class="wc-hero">
    <div class="wc-hero__text">
        <p class="wc-hero__eyebrow">11 June &ndash; 19 July 2026</p>
        <h1 class="wc-hero__title">48 nations. 16 host cities. One trophy.</h1>
        <p class="wc-hero__lede">Follow every group stage table, every kickoff, and every goal across Canada, Mexico and the United States.</p>
        <div class="wc-hero__cta">
            {{#link-to 'groups' class='wc-btn wc-btn--primary'}}View groups{{/link-to}}
            {{#link-to 'schedule' class='wc-btn wc-btn--ghost'}}Full schedule{{/link-to}}
        </div>
    </div>
    <ul class="wc-hero__stats">
        <li><span class="wc-stat__num">48</span><span class="wc-stat__label">Teams</span></li>
        <li><span class="wc-stat__num">12</span><span class="wc-stat__label">Groups</span></li>
        <li><span class="wc-stat__num">104</span><span class="wc-stat__label">Matches</span></li>
        <li><span class="wc-stat__num">16</span><span class="wc-stat__label">Host cities</span></li>
    </ul>
</section>

<section class="wc-panel">
    <div class="wc-panel__head">
        <h2>Host nations</h2>
    </div>
    <ul class="wc-hosts">
        <li><img src="https://flagcdn.com/w160/ca.png" alt="Canada flag"><div><strong>Canada</strong><span>Toronto &middot; Vancouver</span></div></li>
        <li><img src="https://flagcdn.com/w160/mx.png" alt="Mexico flag"><div><strong>Mexico</strong><span>CDMX &middot; Guadalajara &middot; Monterrey</span></div></li>
        <li><img src="https://flagcdn.com/w160/us.png" alt="USA flag"><div><strong>United States</strong><span>11 host cities</span></div></li>
    </ul>
</section>
