<header class="wc-header">
    <div class="wc-header__inner">
        {{#link-to 'index' class='wc-brand' aria-label=(t 'brand.title')}}
            <span class="wc-brand__mark" aria-hidden="true">
                <svg viewBox="0 0 28 36" width="100%" height="100%">
                    <defs>
                        <linearGradient id="wc-brand-gold" x1="0%" y1="0%" x2="0%" y2="100%">
                            <stop offset="0%" stop-color="#fff3c2"></stop>
                            <stop offset="48%" stop-color="#ffd561"></stop>
                            <stop offset="100%" stop-color="#c7870d"></stop>
                        </linearGradient>
                    </defs>
                    <path d="M7 10 Q2 12 2 16 Q2 20 6 21.8" fill="none" stroke="url(#wc-brand-gold)" stroke-width="1.7" stroke-linecap="round"></path>
                    <path d="M21 10 Q26 12 26 16 Q26 20 22 21.8" fill="none" stroke="url(#wc-brand-gold)" stroke-width="1.7" stroke-linecap="round"></path>
                    <path d="M6 7 Q6 3 14 3 Q22 3 22 7 L22 13 Q22 21 17 23 L17 25 L19 25 L19 27 L9 27 L9 25 L11 25 L11 23 Q6 21 6 13 Z"
                          fill="url(#wc-brand-gold)" stroke="#7a4a00" stroke-width="0.55"></path>
                    <path d="M14 3 Q10.5 7 14 11" fill="none" stroke="#7a4a00" stroke-width="0.45" opacity="0.55"></path>
                    <path d="M14 3 Q17.5 7 14 11" fill="none" stroke="#7a4a00" stroke-width="0.45" opacity="0.55"></path>
                    <path d="M7.6 6.2 Q14 8.4 20.4 6.2" fill="none" stroke="#7a4a00" stroke-width="0.45" opacity="0.5"></path>
                    <rect x="7" y="27" width="14" height="2.4" rx="0.4" fill="url(#wc-brand-gold)" stroke="#7a4a00" stroke-width="0.5"></rect>
                    <rect x="4" y="29.4" width="20" height="3.6" rx="0.8" fill="url(#wc-brand-gold)" stroke="#7a4a00" stroke-width="0.5"></rect>
                </svg>
            </span>
            <div class="wc-brand__text">
                <span class="wc-brand__title">{{t 'brand.title'}}</span>
                <span class="wc-brand__sub" aria-label={{t 'brand.subtitle'}}>
                    <img class="wc-brand__flag" src="https://flagcdn.com/w40/ca.png" alt="">
                    <img class="wc-brand__flag" src="https://flagcdn.com/w40/mx.png" alt="">
                    <img class="wc-brand__flag" src="https://flagcdn.com/w40/us.png" alt="">
                </span>
            </div>
        {{/link-to}}
        <nav class="wc-nav">
            {{#link-to 'index' class='wc-nav__link'}}{{t 'nav.home'}}{{/link-to}}
            {{#link-to 'groups' class='wc-nav__link'}}{{t 'nav.groups'}}{{/link-to}}
            {{#link-to 'schedule' class='wc-nav__link'}}{{t 'nav.schedule'}}{{/link-to}}
            {{#link-to 'bracket' class='wc-nav__link'}}{{t 'nav.bracket'}}{{/link-to}}
            {{#link-to 'top-scorers' class='wc-nav__link'}}{{t 'nav.scorers'}}{{/link-to}}
            {{#link-to 'venues' class='wc-nav__link'}}{{t 'nav.venues'}}{{/link-to}}
            {{#link-to 'news' class='wc-nav__link'}}{{t 'nav.news'}}{{/link-to}}
            {{#link-to 'notifications' class='wc-nav__link wc-nav__link--alert'}}
                <svg class="wc-nav__bell" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M6 8a6 6 0 1 1 12 0c0 7 3 7 3 9H3c0-2 3-2 3-9z"></path>
                    <path d="M10.3 21a2 2 0 0 0 3.4 0"></path>
                </svg>
                {{t 'nav.alerts'}}
                <span class="wc-nav__alert-dot" aria-hidden="true"></span>
            {{/link-to}}
        </nav>
        <div class="wc-header__tools">
            {{locale-picker}}
            <button type="button" class="wc-theme-toggle" onclick={{action "toggleTheme"}} aria-label={{t 'theme.toggle'}} title={{t 'theme.toggle'}}>
                <svg class="wc-theme-toggle__icon wc-theme-toggle__icon--sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <circle cx="12" cy="12" r="4" fill="currentColor"></circle>
                    <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="12" y1="2" x2="12" y2="5"></line>
                        <line x1="12" y1="19" x2="12" y2="22"></line>
                        <line x1="2" y1="12" x2="5" y2="12"></line>
                        <line x1="19" y1="12" x2="22" y2="12"></line>
                        <line x1="4.2" y1="4.2" x2="6.3" y2="6.3"></line>
                        <line x1="17.7" y1="17.7" x2="19.8" y2="19.8"></line>
                        <line x1="4.2" y1="19.8" x2="6.3" y2="17.7"></line>
                        <line x1="17.7" y1="6.3" x2="19.8" y2="4.2"></line>
                    </g>
                </svg>
                <svg class="wc-theme-toggle__icon wc-theme-toggle__icon--moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <path d="M20.5 14.5A8 8 0 0 1 9.5 3.5a8 8 0 1 0 11 11z" fill="currentColor"></path>
                </svg>
            </button>
        </div>
    </div>
</header>

<div class="wc-ticker" role="region" aria-label="World Cup 2026 headlines">
    <div class="wc-ticker__track">
        <div class="wc-ticker__group">
            <span class="wc-ticker__item">
                <span class="wc-ticker__tag">{{t 'ticker.tag.kickoff'}}</span>
                <strong>{{t 'footer.kickoff'}}</strong> {{t 'footer.kickoff.detail'}}
            </span>
            <span class="wc-ticker__sep" aria-hidden="true">●</span>
            <span class="wc-ticker__item">
                <span class="wc-ticker__tag">{{t 'ticker.tag.final'}}</span>
                <strong>{{t 'footer.final'}}</strong> {{t 'footer.final.detail'}}
            </span>
            <span class="wc-ticker__sep" aria-hidden="true">●</span>
            <span class="wc-ticker__item">
                <span class="wc-ticker__tag wc-ticker__tag--news">{{t 'ticker.tag.news'}}</span>
                {{t 'ticker.news.placeholder'}}
            </span>
            <span class="wc-ticker__sep" aria-hidden="true">●</span>
        </div>
        <div class="wc-ticker__group" aria-hidden="true">
            <span class="wc-ticker__item">
                <span class="wc-ticker__tag">{{t 'ticker.tag.kickoff'}}</span>
                <strong>{{t 'footer.kickoff'}}</strong> {{t 'footer.kickoff.detail'}}
            </span>
            <span class="wc-ticker__sep">●</span>
            <span class="wc-ticker__item">
                <span class="wc-ticker__tag">{{t 'ticker.tag.final'}}</span>
                <strong>{{t 'footer.final'}}</strong> {{t 'footer.final.detail'}}
            </span>
            <span class="wc-ticker__sep">●</span>
            <span class="wc-ticker__item">
                <span class="wc-ticker__tag wc-ticker__tag--news">{{t 'ticker.tag.news'}}</span>
                {{t 'ticker.news.placeholder'}}
            </span>
            <span class="wc-ticker__sep">●</span>
        </div>
    </div>
</div>

<main class="wc-main">
    {{outlet}}
</main>

<nav class="wc-tabbar" aria-label="Primary">
    {{#link-to 'index' class='wc-tab'}}
        <svg class="wc-tab__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 11 L12 3 L21 11"></path>
            <path d="M5 10 L5 20 L9 20 L9 14 L15 14 L15 20 L19 20 L19 10"></path>
        </svg>
        <span class="wc-tab__label">{{t 'tab.home'}}</span>
    {{/link-to}}
    {{#link-to 'groups' class='wc-tab'}}
        <svg class="wc-tab__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7" rx="1.2"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1.2"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1.2"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1.2"></rect>
        </svg>
        <span class="wc-tab__label">{{t 'tab.groups'}}</span>
    {{/link-to}}
    {{#link-to 'schedule' class='wc-tab'}}
        <svg class="wc-tab__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="5" width="18" height="16" rx="2"></rect>
            <line x1="3" y1="10" x2="21" y2="10"></line>
            <line x1="8" y1="3" x2="8" y2="7"></line>
            <line x1="16" y1="3" x2="16" y2="7"></line>
        </svg>
        <span class="wc-tab__label">{{t 'tab.schedule'}}</span>
    {{/link-to}}
    {{#link-to 'bracket' class='wc-tab'}}
        <svg class="wc-tab__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="6" x2="9" y2="6"></line>
            <line x1="3" y1="18" x2="9" y2="18"></line>
            <line x1="9" y1="6" x2="9" y2="18"></line>
            <line x1="9" y1="12" x2="15" y2="12"></line>
            <line x1="15" y1="12" x2="21" y2="12"></line>
        </svg>
        <span class="wc-tab__label">{{t 'tab.bracket'}}</span>
    {{/link-to}}
    <button type="button"
            class="wc-tab wc-tab--more {{if isMoreOpen 'is-active'}}"
            onclick={{action "toggleMore"}}
            aria-label={{t 'tab.more'}}
            aria-expanded={{isMoreOpen}}
            aria-haspopup="menu">
        <svg class="wc-tab__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <circle cx="5" cy="12" r="1.9"></circle>
            <circle cx="12" cy="12" r="1.9"></circle>
            <circle cx="19" cy="12" r="1.9"></circle>
        </svg>
        <span class="wc-tab__label">{{t 'tab.more'}}</span>
    </button>
</nav>

{{#if isMoreOpen}}
    <div class="wc-more-backdrop" onclick={{action "closeMore"}} aria-hidden="true"></div>
    <div class="wc-more-sheet" role="menu" aria-label={{t 'more.title'}}>
        <div class="wc-more-sheet__handle" aria-hidden="true"></div>
        <div class="wc-more-sheet__grid">
            {{#link-to 'top-scorers' class='wc-more-item'}}
                <svg class="wc-more-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="9"></circle>
                    <polygon points="12,7 15,9.2 13.8,13 10.2,13 9,9.2" fill="currentColor" stroke="none"></polygon>
                </svg>
                <span>{{t 'nav.scorers'}}</span>
            {{/link-to}}
            {{#link-to 'venues' class='wc-more-item'}}
                <svg class="wc-more-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 21 C8 16 5 13 5 10 a7 7 0 1 1 14 0 c0 3 -3 6 -7 11 z"></path>
                    <circle cx="12" cy="10" r="2.5"></circle>
                </svg>
                <span>{{t 'nav.venues'}}</span>
            {{/link-to}}
            {{#link-to 'news' class='wc-more-item'}}
                <svg class="wc-more-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="14" rx="1.5"></rect>
                    <line x1="7" y1="9" x2="17" y2="9"></line>
                    <line x1="7" y1="13" x2="17" y2="13"></line>
                    <line x1="7" y1="17" x2="13" y2="17"></line>
                </svg>
                <span>{{t 'nav.news'}}</span>
            {{/link-to}}
            {{#link-to 'notifications' class='wc-more-item wc-more-item--alert'}}
                <svg class="wc-more-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M6 8a6 6 0 1 1 12 0c0 7 3 7 3 9H3c0-2 3-2 3-9z"></path>
                    <path d="M10.3 21a2 2 0 0 0 3.4 0"></path>
                </svg>
                <span>{{t 'nav.alerts'}}</span>
            {{/link-to}}
            {{#link-to 'about' class='wc-more-item'}}
                <svg class="wc-more-item__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="9"></circle>
                    <line x1="12" y1="11" x2="12" y2="16"></line>
                    <circle cx="12" cy="8" r="0.8" fill="currentColor"></circle>
                </svg>
                <span>{{t 'nav.about'}}</span>
            {{/link-to}}
        </div>
    </div>
{{/if}}

{{#if isHome}}
    {{#link-to 'about' class='wc-about-cta'}}
        <span class="wc-about-cta__avatar" aria-hidden="true">
            <svg viewBox="0 0 40 40" width="44" height="44">
                <defs>
                    <linearGradient id="wc-about-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#ffd561"></stop>
                        <stop offset="100%" stop-color="#e5174a"></stop>
                    </linearGradient>
                </defs>
                <circle cx="20" cy="20" r="19" fill="url(#wc-about-grad)"></circle>
                <text x="20" y="26" text-anchor="middle" font-family="Inter, sans-serif" font-weight="900" font-size="18" fill="#0a1128">JV</text>
            </svg>
        </span>
        <span class="wc-about-cta__text">
            <strong>{{t 'footer.about.cta.title'}}</strong>
            <em>{{t 'footer.about.cta.body'}}</em>
        </span>
        <span class="wc-about-cta__chev" aria-hidden="true">›</span>
    {{/link-to}}
{{/if}}

<footer class="wc-footer">
    <span><strong>{{t 'footer.kickoff'}}</strong> {{t 'footer.kickoff.detail'}}</span>
    <span><strong>{{t 'footer.final'}}</strong> {{t 'footer.final.detail'}}</span>
</footer>

<button type="button"
        class="wc-to-top {{if showToTop 'is-visible'}}"
        onclick={{action "scrollToTop"}}
        aria-label={{t 'action.toTop'}}
        title={{t 'action.toTop'}}>
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6,14 12,8 18,14"></polyline>
    </svg>
</button>
