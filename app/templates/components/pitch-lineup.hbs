<div class="wc-pitch__shell">
    {{#if (eq orientation "landscape")}}
        <svg class="wc-pitch__svg" viewBox="0 0 140 100" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
                <linearGradient id="wc-pitch-turf-l" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#1e8f4a"/>
                    <stop offset="50%" stop-color="#177b3e"/>
                    <stop offset="100%" stop-color="#1e8f4a"/>
                </linearGradient>
                <pattern id="wc-pitch-stripes-l" x="0" y="0" width="20" height="100" patternUnits="userSpaceOnUse">
                    <rect x="0" y="0" width="10" height="100" fill="rgba(255,255,255,0.045)"/>
                </pattern>
            </defs>
            <rect x="0" y="0" width="140" height="100" fill="url(#wc-pitch-turf-l)"/>
            <rect x="0" y="0" width="140" height="100" fill="url(#wc-pitch-stripes-l)"/>
            <!-- outer line -->
            <rect x="2" y="2" width="136" height="96" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <!-- halfway line -->
            <line x1="70" y1="2" x2="70" y2="98" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <circle cx="70" cy="50" r="10" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <circle cx="70" cy="50" r="0.8" fill="rgba(255,255,255,0.8)"/>
            <!-- left penalty box -->
            <rect x="2" y="22" width="18" height="56" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <rect x="2" y="36" width="8" height="28" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <!-- right penalty box -->
            <rect x="120" y="22" width="18" height="56" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <rect x="130" y="36" width="8" height="28" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
        </svg>
    {{else}}
        <svg class="wc-pitch__svg" viewBox="0 0 100 140" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
                <linearGradient id="wc-pitch-turf" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#1e8f4a"/>
                    <stop offset="50%" stop-color="#177b3e"/>
                    <stop offset="100%" stop-color="#1e8f4a"/>
                </linearGradient>
                <pattern id="wc-pitch-stripes" x="0" y="0" width="100" height="20" patternUnits="userSpaceOnUse">
                    <rect width="100" height="10" fill="rgba(255,255,255,0.045)"/>
                </pattern>
            </defs>
            <rect x="0" y="0" width="100" height="140" fill="url(#wc-pitch-turf)"/>
            <rect x="0" y="0" width="100" height="140" fill="url(#wc-pitch-stripes)"/>
            <rect x="2" y="2" width="96" height="136" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <line x1="2" y1="70" x2="98" y2="70" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <circle cx="50" cy="70" r="10" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <circle cx="50" cy="70" r="0.8" fill="rgba(255,255,255,0.8)"/>
            <rect x="22" y="2" width="56" height="18" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <rect x="36" y="2" width="28" height="8" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <rect x="22" y="120" width="56" height="18" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
            <rect x="36" y="130" width="28" height="8" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="0.6"/>
        </svg>
    {{/if}}

    {{#each markers as |p|}}
        <div class="wc-pitch__player" style={{xy-style p.x p.y}}>
            <span class="wc-pitch__avatar" style={{team-hero-style teamCode}}>
                {{#if p.photo}}
                    <img class="wc-pitch__photo" src={{p.photo}} alt="">
                {{else}}
                    <span class="wc-pitch__initial">{{if p.number p.number "·"}}</span>
                {{/if}}
                {{#if p.number}}
                    <span class="wc-pitch__num-badge" style={{team-hero-style teamCode}}>{{p.number}}</span>
                {{/if}}
            </span>
            {{#if p.name}}
                <span class="wc-pitch__name">{{p.name}}</span>
            {{/if}}
        </div>
    {{/each}}

    {{#if formation}}
        <div class="wc-pitch__badge">{{formation}}</div>
    {{/if}}
</div>
