<button type="button"
        class="wc-add-cal__btn"
        onclick={{action "toggle"}}
        aria-label="Add match to calendar"
        aria-expanded={{isOpen}}
        title="Add to calendar">
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
        <rect x="3.5" y="5.5" width="17" height="15" rx="2.5" fill="none" stroke="currentColor" stroke-width="1.8"></rect>
        <line x1="3.5" y1="10" x2="20.5" y2="10" stroke="currentColor" stroke-width="1.8"></line>
        <line x1="8.5" y1="3" x2="8.5" y2="7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></line>
        <line x1="15.5" y1="3" x2="15.5" y2="7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></line>
        <rect x="11" y="13.5" width="3" height="3" rx="0.5" fill="currentColor"></rect>
    </svg>
</button>

{{#if isOpen}}
    <div class="wc-add-cal__menu" role="menu">
        <button type="button" class="wc-add-cal__opt" role="menuitem" onclick={{action "downloadIcs"}}>
            <svg class="wc-add-cal__opt-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                <path d="M12 2a5 5 0 0 0-5 5c0 2.4 1.4 4 1.4 6 0 1.3-.8 2.2-.8 3.8 0 2.3 2 4.4 4.4 5.2.3-.1.6-.4.6-.9 0-.4-.2-.7-.5-.8-2-.7-3.5-2-3.5-3.5 0-1.1.6-1.9.6-3 0-1.6-1.2-3.2-1.2-4.8a3 3 0 1 1 6 0 3 3 0 0 0 3 3c.6 0 1-.5 1-1s-.4-1-1-1a1 1 0 0 1-1-1 5 5 0 0 0-5-2z" fill="currentColor"/>
            </svg>
            <span class="wc-add-cal__opt-text">
                <strong>Apple / iOS</strong>
                <em>Downloads an .ics file</em>
            </span>
        </button>
        <a class="wc-add-cal__opt" role="menuitem" href={{gcalUrl}} target="_blank" rel="noopener" onclick={{action "close"}}>
            <svg class="wc-add-cal__opt-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                <rect x="3" y="5" width="18" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/>
                <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.8"/>
                <text x="12" y="17.5" text-anchor="middle" font-size="6" font-weight="800" fill="currentColor" font-family="Inter, sans-serif">G</text>
            </svg>
            <span class="wc-add-cal__opt-text">
                <strong>Google Calendar</strong>
                <em>Opens in a new tab</em>
            </span>
        </a>
        <a class="wc-add-cal__opt" role="menuitem" href={{outlookUrl}} target="_blank" rel="noopener" onclick={{action "close"}}>
            <svg class="wc-add-cal__opt-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                <rect x="3" y="5" width="18" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/>
                <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.8"/>
                <text x="12" y="17.5" text-anchor="middle" font-size="6" font-weight="800" fill="currentColor" font-family="Inter, sans-serif">O</text>
            </svg>
            <span class="wc-add-cal__opt-text">
                <strong>Outlook</strong>
                <em>Opens Outlook Web</em>
            </span>
        </a>
    </div>
{{/if}}
