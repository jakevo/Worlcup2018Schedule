<section class="wc-page-head">
    <div>
        <h1>{{t 'schedule.title'}}</h1>
        <p>{{t 'schedule.subtitle'}}</p>
    </div>
    <button type="button" class="wc-btn wc-btn--ghost" onclick={{action "refresh"}}>{{t 'action.refresh'}}</button>
</section>

<div class="wc-filters">
    <div class="wc-filters__row">
        <label class="wc-search">
            <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true">
                <circle cx="9" cy="9" r="6" fill="none" stroke="currentColor" stroke-width="2"></circle>
                <line x1="13.5" y1="13.5" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
            </svg>
            {{input
                type="search"
                value=searchQuery
                placeholder=(t 'schedule.search.placeholder')
                class="wc-search__input"}}
        </label>
        <label class="wc-toggle">
            {{input type="checkbox" checked=showPlayedOnly}}
            <span>{{t 'schedule.filter.playedOnly'}}</span>
        </label>
        {{#if (or (not-eq groupFilter 'all') searchQuery showPlayedOnly)}}
            <button type="button" class="wc-btn wc-btn--ghost wc-btn--sm" onclick={{action "clearFilters"}}>{{t 'action.clear'}}</button>
        {{/if}}
    </div>
    <div class="wc-chips">
        <button type="button"
                class="wc-chip {{if (eq groupFilter 'all') 'is-active'}}"
                onclick={{action "setGroupFilter" "all"}}>{{t 'schedule.chip.all'}}</button>
        {{#each allGroups as |letter|}}
            <button type="button"
                    class="wc-chip {{if (eq groupFilter letter) 'is-active'}}"
                    onclick={{action "setGroupFilter" letter}}>{{letter}}</button>
        {{/each}}
    </div>
    <div class="wc-filters__summary">
        {{t 'schedule.summary.showing'}} <strong>{{totalFiltered}}</strong> {{t 'schedule.summary.of'}} {{model.matches.length}} {{t 'schedule.summary.matches'}}
    </div>
</div>

{{#if allDays.length}}
    <nav class="wc-daystrip" aria-label="{{t 'schedule.dayStrip.aria'}}">
        <ol class="wc-daystrip__list">
            <li>
                <button type="button"
                        class="wc-daystrip__item wc-daystrip__item--all {{unless activeDate 'is-active'}}"
                        onclick={{action "showAllDates"}}>
                    <span class="wc-daystrip__all">{{t 'schedule.dayStrip.all'}}</span>
                </button>
            </li>
            {{#each allDays as |day|}}
                <li>
                    <button type="button"
                            class="wc-daystrip__item {{if (eq day.date activeDate) 'is-active'}}"
                            onclick={{action "selectDate" day.date}}>
                        <span class="wc-daystrip__dow">{{weekday day.date}}</span>
                        <span class="wc-daystrip__num">{{day-num day.date}}</span>
                        <span class="wc-daystrip__month">{{month-short day.date}}</span>
                    </button>
                </li>
            {{/each}}
        </ol>
    </nav>
{{/if}}

<div class="wc-schedule">
    {{#each filteredDays as |day|}}
        <section class="wc-day" id="wc-day-{{day.date}}">
            <header class="wc-day__head">
                <span class="wc-day__weekday">{{weekday day.date}}</span>
                <h2 class="wc-day__date">{{long-date day.date}}</h2>
                <span class="wc-day__count">{{day.matches.length}} {{t 'schedule.summary.matches'}}</span>
            </header>
            <ul class="wc-day__matches">
                {{#each day.matches as |match|}}
                    <li class="wc-match {{if match.played 'is-played'}} {{if match.isLive 'is-live'}}">
                        {{#link-to 'match' match.id class='wc-match__time' title=(t 'match.details')}}
                            <span class="wc-match__group">{{match.group}}</span>
                            {{#if match.isLive}}
                                <span class="wc-live-badge"><span class="wc-live-badge__dot"></span>{{t 'live'}}</span>
                            {{else}}
                                <span class="wc-match__kick">{{format-time match.time}}</span>
                            {{/if}}
                        {{/link-to}}
                        <div class="wc-match__body">
                            <div class="wc-match__teams">
                                {{#if match.team1Code}}
                                    {{#link-to 'team' match.team1Code class='wc-match__team'}}
                                        {{#if match.team1Flag}}<img src={{match.team1Flag}} alt="">{{/if}}
                                        <span class="wc-match__name">{{match.team1}}</span>
                                    {{/link-to}}
                                {{else}}
                                    <div class="wc-match__team">
                                        {{#if match.team1Flag}}<img src={{match.team1Flag}} alt="">{{/if}}
                                        <span class="wc-match__name">{{match.team1}}</span>
                                    </div>
                                {{/if}}
                                <div class="wc-match__score">
                                    {{#if match.played}}
                                        <span>{{match.score1}}</span>
                                        <span class="wc-match__dash">&ndash;</span>
                                        <span>{{match.score2}}</span>
                                    {{else}}
                                        <span class="wc-match__vs">{{t 'match.vs'}}</span>
                                    {{/if}}
                                </div>
                                {{#if match.team2Code}}
                                    {{#link-to 'team' match.team2Code class='wc-match__team wc-match__team--right'}}
                                        <span class="wc-match__name">{{match.team2}}</span>
                                        {{#if match.team2Flag}}<img src={{match.team2Flag}} alt="">{{/if}}
                                    {{/link-to}}
                                {{else}}
                                    <div class="wc-match__team wc-match__team--right">
                                        <span class="wc-match__name">{{match.team2}}</span>
                                        {{#if match.team2Flag}}<img src={{match.team2Flag}} alt="">{{/if}}
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                        {{add-to-calendar match=match}}
                        <div class="wc-match__venue">{{match.venue}} &middot; {{match.city}}</div>
                    </li>
                {{/each}}
            </ul>
        </section>
    {{else}}
        <div class="wc-empty">
            <p>{{t 'schedule.empty'}}</p>
            <button type="button" class="wc-btn wc-btn--ghost" onclick={{action "clearFilters"}}>{{t 'action.clearFilters'}}</button>
        </div>
    {{/each}}
</div>
