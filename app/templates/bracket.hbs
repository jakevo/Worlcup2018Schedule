<header class="wc-bracket-head">
    <div class="wc-bracket-head__inner">
        <div>
            <h1>{{t 'bracket.title'}}</h1>
            <p>{{t 'bracket.subtitle'}}</p>
            <p class="wc-bracket-head__legend">{{t 'bracket.legend'}}</p>
        </div>
        <div class="wc-bracket-toolbar">
            <button type="button"
                    class="wc-bracket-toolbar__btn wc-bracket-toolbar__btn--predict {{if predictMode 'is-on is-active'}}"
                    onclick={{action "togglePredict"}}>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M3 12l5 5L21 4"/></svg>
                {{t 'bracket.predict_mode'}}
            </button>
        </div>
    </div>
</header>

<main class="bracket-page">
    {{#if predictMode}}
        <div class="predict-banner">
            <span class="predict-banner__pulse"></span>
            <span><strong>{{t 'bracket.predict_mode'}}</strong> — {{t 'bracket.predict_hint'}}</span>
            {{#if hasPicks}}
                <button type="button" class="predict-banner__btn" onclick={{action "resetPicks"}}>
                    {{t 'bracket.reset_picks'}}
                </button>
            {{/if}}
        </div>
    {{/if}}

    {{#if showSimulateBanner}}
        <div class="sim-banner">
            <div class="sim-banner__text">
                <strong>{{t 'bracket.simulate.title'}}</strong>
                <span>{{t 'bracket.simulate.body'}}</span>
            </div>
            <button type="button" class="sim-banner__btn sim-banner__btn--primary" onclick={{action "simulateStandings"}}>{{t 'bracket.simulate.cta'}}</button>
        </div>
    {{/if}}
    {{#if showSimulationActive}}
        <div class="sim-banner sim-banner--active">
            <div class="sim-banner__text">
                <strong>{{t 'bracket.simulate.activeTitle'}}</strong>
                <span>{{t 'bracket.simulate.activeBody'}}</span>
            </div>
            <button type="button" class="sim-banner__btn" onclick={{action "simulateStandings"}}>{{t 'bracket.simulate.regenerate'}}</button>
            <button type="button" class="sim-banner__btn sim-banner__btn--ghost" onclick={{action "clearSimulation"}}>{{t 'bracket.simulate.clear'}}</button>
        </div>
    {{/if}}

    <div class="bracket-shell">
        {{!-- Desktop full tree --}}
        <div class="bracket-desktop-only">
            <div class="bt {{if hoveredTeamCode 'bt--hovering'}} {{if champion 'bt--crowned'}}">
                {{bp-confetti active=champion}}

                <div class="bt__rounds">
                    <div class="bt__rcell">{{t 'bracket.round.r32'}}</div>
                    <div class="bt__rcell">{{t 'bracket.round.r16'}}</div>
                    <div class="bt__rcell">{{t 'bracket.round.qf'}}</div>
                    <div class="bt__rcell">{{t 'bracket.round.sf'}}</div>
                    <div class="bt__rcell bt__rcell--final">{{t 'bracket.round.final'}}</div>
                    <div class="bt__rcell">{{t 'bracket.round.sf'}}</div>
                    <div class="bt__rcell">{{t 'bracket.round.qf'}}</div>
                    <div class="bt__rcell">{{t 'bracket.round.r16'}}</div>
                    <div class="bt__rcell">{{t 'bracket.round.r32'}}</div>
                </div>
                <div class="bt__dates">
                    <div class="bt__dcell">{{t 'bracket.dates.r32'}}</div>
                    <div class="bt__dcell">{{t 'bracket.dates.r16'}}</div>
                    <div class="bt__dcell">{{t 'bracket.dates.qf'}}</div>
                    <div class="bt__dcell">{{t 'bracket.dates.sf'}}</div>
                    <div class="bt__dcell bt__dcell--final">{{t 'bracket.dates.final_short'}}</div>
                    <div class="bt__dcell">{{t 'bracket.dates.sf'}}</div>
                    <div class="bt__dcell">{{t 'bracket.dates.qf'}}</div>
                    <div class="bt__dcell">{{t 'bracket.dates.r16'}}</div>
                    <div class="bt__dcell">{{t 'bracket.dates.r32'}}</div>
                </div>

                <div class="bt__grid-wrap">
                    {{bp-connector-layer rounds=rounds picks=picks}}
                    <div class="bt__grid">

                    <div class="bt__col bt__col--r32 bt__col--left">
                        {{#each leftR32 key="id" as |m|}}
                            {{bp-tree-match
                                match=m
                                highlightedMatchIds=highlightedMatchIds
                                hoveredTeamCode=hoveredTeamCode
                                focusedEmptyId=focusedEmptyId
                                focusedFeeders=focusedFeeders
                                predictMode=predictMode
                                onHoverTeam=(action "hoverTeam")
                                onPick=(action "onPick")
                                onFocusEmpty=(action "onFocusEmpty")}}
                        {{/each}}
                    </div>
                    <div class="bt__col bt__col--r16 bt__col--left">
                        {{#each leftR16 key="id" as |m|}}
                            {{bp-tree-match
                                match=m
                                highlightedMatchIds=highlightedMatchIds
                                hoveredTeamCode=hoveredTeamCode
                                focusedEmptyId=focusedEmptyId
                                focusedFeeders=focusedFeeders
                                predictMode=predictMode
                                onHoverTeam=(action "hoverTeam")
                                onPick=(action "onPick")
                                onFocusEmpty=(action "onFocusEmpty")}}
                        {{/each}}
                    </div>
                    <div class="bt__col bt__col--qf bt__col--left">
                        {{#each leftQF key="id" as |m|}}
                            {{bp-tree-match
                                match=m
                                highlightedMatchIds=highlightedMatchIds
                                hoveredTeamCode=hoveredTeamCode
                                focusedEmptyId=focusedEmptyId
                                focusedFeeders=focusedFeeders
                                predictMode=predictMode
                                onHoverTeam=(action "hoverTeam")
                                onPick=(action "onPick")
                                onFocusEmpty=(action "onFocusEmpty")}}
                        {{/each}}
                    </div>
                    <div class="bt__col bt__col--sf bt__col--left">
                        {{#each leftSF key="id" as |m|}}
                            {{bp-tree-match
                                match=m
                                highlightedMatchIds=highlightedMatchIds
                                hoveredTeamCode=hoveredTeamCode
                                focusedEmptyId=focusedEmptyId
                                focusedFeeders=focusedFeeders
                                predictMode=predictMode
                                onHoverTeam=(action "hoverTeam")
                                onPick=(action "onPick")
                                onFocusEmpty=(action "onFocusEmpty")}}
                        {{/each}}
                    </div>

                    <div class="bt__col bt__col--final">
                        <div class="bt__trophy" aria-hidden="true">
                            <svg viewBox="0 0 80 100" width="100%" height="100%">
                                <defs>
                                    <linearGradient id="bt-trophy-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                                        <stop offset="0%" stop-color="#fff3c2"/>
                                        <stop offset="40%" stop-color="#ffd561"/>
                                        <stop offset="100%" stop-color="#c7870d"/>
                                    </linearGradient>
                                    <radialGradient id="bt-trophy-glow" cx="50%" cy="50%">
                                        <stop offset="0%" stop-color="#ffd561" stop-opacity="0.5"/>
                                        <stop offset="100%" stop-color="#ffd561" stop-opacity="0"/>
                                    </radialGradient>
                                </defs>
                                <circle cx="40" cy="40" r="40" fill="url(#bt-trophy-glow)" class="bt__trophy-aura"/>
                                <path d="M24 8h32v18a16 16 0 0 1-32 0V8z" fill="url(#bt-trophy-grad)" stroke="#7a4a00" stroke-width="1"/>
                                <path d="M24 14H10v8a10 10 0 0 0 10 10" fill="none" stroke="url(#bt-trophy-grad)" stroke-width="3" stroke-linecap="round"/>
                                <path d="M56 14h14v8a10 10 0 0 1-10 10" fill="none" stroke="url(#bt-trophy-grad)" stroke-width="3" stroke-linecap="round"/>
                                <rect x="32" y="44" width="16" height="8" fill="url(#bt-trophy-grad)" stroke="#7a4a00" stroke-width="0.8"/>
                                <rect x="24" y="52" width="32" height="8" rx="1" fill="url(#bt-trophy-grad)" stroke="#7a4a00" stroke-width="0.8"/>
                                <rect x="18" y="60" width="44" height="10" rx="2" fill="url(#bt-trophy-grad)" stroke="#7a4a00" stroke-width="0.8"/>
                            </svg>
                        </div>

                        <div class="bt__final-wrap">
                            {{#if finalMatch}}
                                {{bp-tree-match
                                    match=finalMatch
                                    isFinal=true
                                    big=true
                                    highlightedMatchIds=highlightedMatchIds
                                    hoveredTeamCode=hoveredTeamCode
                                    focusedEmptyId=focusedEmptyId
                                    focusedFeeders=focusedFeeders
                                    predictMode=predictMode
                                    onHoverTeam=(action "hoverTeam")
                                    onPick=(action "onPick")
                                    onFocusEmpty=(action "onFocusEmpty")}}
                            {{/if}}
                        </div>

                        {{#if champion}}
                            <div class="bt__champion">
                                <div class="bt__champion-rays" aria-hidden="true">
                                    <span style="transform: rotate(0deg)"></span>
                                    <span style="transform: rotate(30deg)"></span>
                                    <span style="transform: rotate(60deg)"></span>
                                    <span style="transform: rotate(90deg)"></span>
                                    <span style="transform: rotate(120deg)"></span>
                                    <span style="transform: rotate(150deg)"></span>
                                    <span style="transform: rotate(180deg)"></span>
                                    <span style="transform: rotate(210deg)"></span>
                                    <span style="transform: rotate(240deg)"></span>
                                    <span style="transform: rotate(270deg)"></span>
                                    <span style="transform: rotate(300deg)"></span>
                                    <span style="transform: rotate(330deg)"></span>
                                </div>
                                <div class="bt__champion-label">{{t 'bracket.champion_label'}}</div>
                                <div class="bt__champion-flag"><img src={{champion.flag}} alt={{champion.name}}></div>
                                <div class="bt__champion-name">{{champion.fifaCode}}</div>
                                <div class="bt__champion-sub">{{t 'bracket.champion_sub'}}</div>
                            </div>
                        {{/if}}
                    </div>

                    <div class="bt__col bt__col--sf bt__col--right">
                        {{#each rightSF key="id" as |m|}}
                            {{bp-tree-match
                                match=m
                                highlightedMatchIds=highlightedMatchIds
                                hoveredTeamCode=hoveredTeamCode
                                focusedEmptyId=focusedEmptyId
                                focusedFeeders=focusedFeeders
                                predictMode=predictMode
                                onHoverTeam=(action "hoverTeam")
                                onPick=(action "onPick")
                                onFocusEmpty=(action "onFocusEmpty")}}
                        {{/each}}
                    </div>
                    <div class="bt__col bt__col--qf bt__col--right">
                        {{#each rightQF key="id" as |m|}}
                            {{bp-tree-match
                                match=m
                                highlightedMatchIds=highlightedMatchIds
                                hoveredTeamCode=hoveredTeamCode
                                focusedEmptyId=focusedEmptyId
                                focusedFeeders=focusedFeeders
                                predictMode=predictMode
                                onHoverTeam=(action "hoverTeam")
                                onPick=(action "onPick")
                                onFocusEmpty=(action "onFocusEmpty")}}
                        {{/each}}
                    </div>
                    <div class="bt__col bt__col--r16 bt__col--right">
                        {{#each rightR16 key="id" as |m|}}
                            {{bp-tree-match
                                match=m
                                highlightedMatchIds=highlightedMatchIds
                                hoveredTeamCode=hoveredTeamCode
                                focusedEmptyId=focusedEmptyId
                                focusedFeeders=focusedFeeders
                                predictMode=predictMode
                                onHoverTeam=(action "hoverTeam")
                                onPick=(action "onPick")
                                onFocusEmpty=(action "onFocusEmpty")}}
                        {{/each}}
                    </div>
                    <div class="bt__col bt__col--r32 bt__col--right">
                        {{#each rightR32 key="id" as |m|}}
                            {{bp-tree-match
                                match=m
                                highlightedMatchIds=highlightedMatchIds
                                hoveredTeamCode=hoveredTeamCode
                                focusedEmptyId=focusedEmptyId
                                focusedFeeders=focusedFeeders
                                predictMode=predictMode
                                onHoverTeam=(action "hoverTeam")
                                onPick=(action "onPick")
                                onFocusEmpty=(action "onFocusEmpty")}}
                        {{/each}}
                    </div>
                    </div>
                </div>
            </div>
        </div>

        {{!-- Mobile horizontal swipe --}}
        <div class="bracket-mobile-only">
            {{bp-mobile-bracket
                rounds=rounds
                picks=picks
                champion=champion
                predictMode=predictMode
                hoveredTeamCode=hoveredTeamCode
                highlightedMatchIds=highlightedMatchIds
                focusedEmptyId=focusedEmptyId
                focusedFeeders=focusedFeeders
                onHoverTeam=(action "hoverTeam")
                onPick=(action "onPick")
                onFocusEmpty=(action "onFocusEmpty")}}
        </div>
    </div>
</main>
