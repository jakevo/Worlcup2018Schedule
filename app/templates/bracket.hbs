<section class="wc-page-head">
    <div>
        <h1>{{t 'bracket.title'}}</h1>
        <p>{{t 'bracket.subtitle'}}</p>
        <p class="wc-bracket__legend">{{t 'bracket.legend'}}</p>
    </div>
</section>

<div class="wc-bp2">
    <div class="wc-bp2__tabs" role="tablist">
        {{#each model.rounds as |round idx|}}
            <button class="wc-bp2__tab {{if (eq idx activeRoundIndex) 'is-active'}}"
                    onclick={{action "selectRound" idx}}
                    role="tab"
                    aria-selected={{eq idx activeRoundIndex}}>
                {{t (concat 'bracket.round.' round.key)}}
            </button>
        {{/each}}
    </div>

    {{#bp-rounds rounds=model.rounds activeIndex=activeRoundIndex onActivate=(action "selectRound") as |round|}}
        <p class="wc-bp2__round-dates">{{t (concat 'bracket.dates.' round.key)}}</p>
        <div class="wc-bp2__matches">
            {{#each round.matches as |match|}}
                <article class="wc-bp2-match">
                    <div class="wc-bp2-match__when">
                        {{#if match.fixture}}
                            {{weekday match.fixture.date}} {{short-date match.fixture.date}} · {{format-time match.fixture.time}}
                        {{else}}
                            <span class="wc-bp2-match__id">{{match.id}}</span>
                        {{/if}}
                    </div>

                    <div class="wc-bp2-match__row">
                        {{#if match.top.team.flag}}
                            <span class="wc-bp2-match__flag"><img src={{match.top.team.flag}} alt=""></span>
                        {{else}}
                            <span class="wc-bp2-match__flag wc-bp2-match__flag--empty"></span>
                        {{/if}}
                        <span class="wc-bp2-match__name">
                            {{#if match.top.team.name}}
                                {{match.top.team.name}}
                            {{else if match.top.winnerOf}}
                                {{t 'bracket.winner'}} {{match.top.winnerOf}}
                            {{else}}
                                {{match.top.label}}
                            {{/if}}
                        </span>
                        <span class="wc-bp2-match__seed">{{match.top.label}}</span>
                    </div>

                    <div class="wc-bp2-match__row">
                        {{#if match.bot.team.flag}}
                            <span class="wc-bp2-match__flag"><img src={{match.bot.team.flag}} alt=""></span>
                        {{else}}
                            <span class="wc-bp2-match__flag wc-bp2-match__flag--empty"></span>
                        {{/if}}
                        <span class="wc-bp2-match__name">
                            {{#if match.bot.team.name}}
                                {{match.bot.team.name}}
                            {{else if match.bot.winnerOf}}
                                {{t 'bracket.winner'}} {{match.bot.winnerOf}}
                            {{else}}
                                {{match.bot.label}}
                            {{/if}}
                        </span>
                        <span class="wc-bp2-match__seed">{{match.bot.label}}</span>
                    </div>
                </article>
            {{/each}}
        </div>
    {{/bp-rounds}}

    <div class="wc-bp2__hint">
        <span aria-hidden="true">←</span>
        {{t 'bracket.swipeHint'}}
        <span aria-hidden="true">→</span>
    </div>
</div>

{{!-- Desktop full-tree (hidden on small screens via CSS) --}}
<div class="wc-bp-tree {{if hoveredTeamCode 'is-hovering'}}">
    <div class="wc-bp-tree__bg" aria-hidden="true"></div>

    <div class="wc-bp-tree__col wc-bp-tree__col--left wc-bp-tree__col--r32">
        <h3 class="wc-bp-tree__col-title">{{t 'bracket.round.r32'}}</h3>
        {{#each r32LeftPairs as |pair|}}
            <div class="wc-bp-tree-pair">
                {{#each pair as |m|}}
                    {{bp-tree-match match=m
                                    highlightedMatchIds=highlightedMatchIds
                                    expandedMatchId=expandedMatchId
                                    onHoverTeam=(action "hoverTeam")
                                    onToggle=(action "toggleMatch")}}
                {{/each}}
            </div>
        {{/each}}
    </div>
    <div class="wc-bp-tree__col wc-bp-tree__col--left wc-bp-tree__col--r16">
        <h3 class="wc-bp-tree__col-title">{{t 'bracket.round.r16'}}</h3>
        {{#each r16LeftPairs as |pair|}}
            <div class="wc-bp-tree-pair">
                {{#each pair as |m|}}
                    {{bp-tree-match match=m
                                    highlightedMatchIds=highlightedMatchIds
                                    expandedMatchId=expandedMatchId
                                    onHoverTeam=(action "hoverTeam")
                                    onToggle=(action "toggleMatch")}}
                {{/each}}
            </div>
        {{/each}}
    </div>
    <div class="wc-bp-tree__col wc-bp-tree__col--left wc-bp-tree__col--qf">
        <h3 class="wc-bp-tree__col-title">{{t 'bracket.round.qf'}}</h3>
        {{#each qfLeftPairs as |pair|}}
            <div class="wc-bp-tree-pair">
                {{#each pair as |m|}}
                    {{bp-tree-match match=m
                                    highlightedMatchIds=highlightedMatchIds
                                    expandedMatchId=expandedMatchId
                                    onHoverTeam=(action "hoverTeam")
                                    onToggle=(action "toggleMatch")}}
                {{/each}}
            </div>
        {{/each}}
    </div>
    <div class="wc-bp-tree__col wc-bp-tree__col--left wc-bp-tree__col--sf">
        <h3 class="wc-bp-tree__col-title">{{t 'bracket.round.sf'}}</h3>
        {{#each sfLeft as |m|}}
            {{bp-tree-match match=m
                            highlightedMatchIds=highlightedMatchIds
                            expandedMatchId=expandedMatchId
                            onHoverTeam=(action "hoverTeam")
                            onToggle=(action "toggleMatch")}}
        {{/each}}
    </div>

    <div class="wc-bp-tree__col wc-bp-tree__col--final">
        <div class="wc-bp-tree__trophy" aria-hidden="true">
            <svg viewBox="0 0 64 64" width="56" height="56" fill="none">
                <defs>
                    <linearGradient id="wc-bp-tree-gold" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" stop-color="#ffe27a"/>
                        <stop offset="100%" stop-color="#c89200"/>
                    </linearGradient>
                </defs>
                <path d="M20 8h24v14a12 12 0 0 1-24 0V8z" fill="url(#wc-bp-tree-gold)" stroke="#8a6500" stroke-width="1.4"/>
                <path d="M20 12H10v6a8 8 0 0 0 8 8" fill="none" stroke="url(#wc-bp-tree-gold)" stroke-width="2.4" stroke-linecap="round"/>
                <path d="M44 12h10v6a8 8 0 0 1-8 8" fill="none" stroke="url(#wc-bp-tree-gold)" stroke-width="2.4" stroke-linecap="round"/>
                <rect x="26" y="36" width="12" height="6" fill="url(#wc-bp-tree-gold)" stroke="#8a6500"/>
                <rect x="20" y="42" width="24" height="6" rx="2" fill="url(#wc-bp-tree-gold)" stroke="#8a6500"/>
                <rect x="16" y="48" width="32" height="6" rx="2" fill="url(#wc-bp-tree-gold)" stroke="#8a6500"/>
            </svg>
        </div>
        <h3 class="wc-bp-tree__col-title wc-bp-tree__col-title--final">{{t 'bracket.round.final'}}</h3>
        {{#if finalMatch}}
            {{bp-tree-match match=finalMatch
                            highlightedMatchIds=highlightedMatchIds
                            expandedMatchId=expandedMatchId
                            onHoverTeam=(action "hoverTeam")
                            onToggle=(action "toggleMatch")}}
        {{/if}}
        <p class="wc-bp-tree__final-date">{{t 'bracket.dates.final'}}</p>
    </div>

    <div class="wc-bp-tree__col wc-bp-tree__col--right wc-bp-tree__col--sf">
        <h3 class="wc-bp-tree__col-title">{{t 'bracket.round.sf'}}</h3>
        {{#each sfRight as |m|}}
            {{bp-tree-match match=m
                            highlightedMatchIds=highlightedMatchIds
                            expandedMatchId=expandedMatchId
                            onHoverTeam=(action "hoverTeam")
                            onToggle=(action "toggleMatch")}}
        {{/each}}
    </div>
    <div class="wc-bp-tree__col wc-bp-tree__col--right wc-bp-tree__col--qf">
        <h3 class="wc-bp-tree__col-title">{{t 'bracket.round.qf'}}</h3>
        {{#each qfRightPairs as |pair|}}
            <div class="wc-bp-tree-pair">
                {{#each pair as |m|}}
                    {{bp-tree-match match=m
                                    highlightedMatchIds=highlightedMatchIds
                                    expandedMatchId=expandedMatchId
                                    onHoverTeam=(action "hoverTeam")
                                    onToggle=(action "toggleMatch")}}
                {{/each}}
            </div>
        {{/each}}
    </div>
    <div class="wc-bp-tree__col wc-bp-tree__col--right wc-bp-tree__col--r16">
        <h3 class="wc-bp-tree__col-title">{{t 'bracket.round.r16'}}</h3>
        {{#each r16RightPairs as |pair|}}
            <div class="wc-bp-tree-pair">
                {{#each pair as |m|}}
                    {{bp-tree-match match=m
                                    highlightedMatchIds=highlightedMatchIds
                                    expandedMatchId=expandedMatchId
                                    onHoverTeam=(action "hoverTeam")
                                    onToggle=(action "toggleMatch")}}
                {{/each}}
            </div>
        {{/each}}
    </div>
    <div class="wc-bp-tree__col wc-bp-tree__col--right wc-bp-tree__col--r32">
        <h3 class="wc-bp-tree__col-title">{{t 'bracket.round.r32'}}</h3>
        {{#each r32RightPairs as |pair|}}
            <div class="wc-bp-tree-pair">
                {{#each pair as |m|}}
                    {{bp-tree-match match=m
                                    highlightedMatchIds=highlightedMatchIds
                                    expandedMatchId=expandedMatchId
                                    onHoverTeam=(action "hoverTeam")
                                    onToggle=(action "toggleMatch")}}
                {{/each}}
            </div>
        {{/each}}
    </div>
</div>
