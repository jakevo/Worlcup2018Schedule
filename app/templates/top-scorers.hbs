<section class="wc-page-head">
    <div>
        <h1>{{t 'scorers.title'}}</h1>
        <p>{{t 'scorers.subtitle'}}</p>
    </div>
</section>

{{#if model.scorers.length}}
    <ol class="wc-scorers">
        {{#each model.scorers as |s index|}}
            <li class="wc-scorer">
                <span class="wc-scorer__rank">{{inc index}}</span>
                {{#if s.playerPhoto}}<img class="wc-scorer__photo" src={{s.playerPhoto}} alt="">{{/if}}
                <div class="wc-scorer__body">
                    <strong class="wc-scorer__name">{{s.player}}</strong>
                    <span class="wc-scorer__team">
                        {{#if s.teamFlag}}<img src={{s.teamFlag}} alt="">{{/if}}
                        {{s.team}}
                    </span>
                </div>
                <span class="wc-scorer__goals">{{s.goals}}</span>
            </li>
        {{/each}}
    </ol>
{{else}}
    <section class="wc-placeholder wc-placeholder--lg">
        <svg viewBox="0 0 48 48" width="48" height="48" aria-hidden="true">
            <circle cx="24" cy="24" r="20" fill="none" stroke="currentColor" stroke-width="2"/>
            <polygon points="24,14 30,18 27.5,26 20.5,26 18,18" fill="currentColor" opacity="0.8"/>
            <line x1="24" y1="4" x2="24" y2="14" stroke="currentColor" stroke-width="1.4"/>
            <line x1="30" y1="18" x2="40" y2="14" stroke="currentColor" stroke-width="1.4"/>
            <line x1="27.5" y1="26" x2="34" y2="34" stroke="currentColor" stroke-width="1.4"/>
            <line x1="20.5" y1="26" x2="14" y2="34" stroke="currentColor" stroke-width="1.4"/>
            <line x1="18" y1="18" x2="8" y2="14" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        <h3>{{t 'scorers.empty.title'}}</h3>
        <p>{{t 'scorers.empty.body'}}</p>
    </section>
{{/if}}
