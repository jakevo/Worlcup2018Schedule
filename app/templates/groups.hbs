<section class="wc-page-head">
    <div>
        <h1>Group stage</h1>
        <p>48 teams across 12 groups. Top two plus the eight best third-placed teams advance to the Round of 32.</p>
    </div>
    <button type="button" class="wc-btn wc-btn--ghost" onclick={{action "refresh"}}>Refresh</button>
</section>

<div class="wc-groups">
    {{#each model.groups as |group|}}
        <article class="wc-group">
            <header class="wc-group__head">
                <span class="wc-group__badge">Group {{group.letter}}</span>
                <span class="wc-group__hint">Top 2 advance</span>
            </header>
            <table class="wc-table">
                <thead>
                    <tr>
                        <th class="wc-table__pos">#</th>
                        <th class="wc-table__team">Team</th>
                        <th><abbr title="Matches Played">MP</abbr></th>
                        <th><abbr title="Wins">W</abbr></th>
                        <th><abbr title="Draws">D</abbr></th>
                        <th><abbr title="Losses">L</abbr></th>
                        <th><abbr title="Goal Difference">GD</abbr></th>
                        <th><abbr title="Points">Pts</abbr></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each group.teams as |team index|}}
                        <tr>
                            <td class="wc-table__pos">{{inc index}}</td>
                            <td class="wc-table__team">
                                <img src={{team.flag}} alt="">
                                <span class="wc-table__team-name">{{team.name}}</span>
                            </td>
                            <td>{{team.mp}}</td>
                            <td>{{team.w}}</td>
                            <td>{{team.d}}</td>
                            <td>{{team.l}}</td>
                            <td>{{team.gd}}</td>
                            <td class="wc-table__pts">{{team.pts}}</td>
                        </tr>
                    {{/each}}
                </tbody>
            </table>
            <div class="wc-group__legend">Qualifies for Round of 32</div>
        </article>
    {{/each}}
</div>
